generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id            String         @id @default(cuid())
  name          String         @default("")
  description   String         @default("")
  emoji         String         @default("📁")
  color         String         @default("#d4a853")
  isArchived    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  characters    Character[]
  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId        String?
  genre         String         @default("")
  format        String         @default("")
  setting       String         @default("")
  worldElements WorldElement[]
}

model WorldElement {
  id          String   @id @default(cuid())
  title       String   @default("")
  content     String   @default("")
  category    String   @default("location") // location, faction, history, rule, other
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Character {
  id         String   @id @default(cuid())
  name       String   @default("")
  nickname   String   @default("")
  data       String   @default("{}")
  emoji      String   @default("👤")
  color      String   @default("#d4a853")
  summary    String   @default("")
  isDraft    Boolean  @default(true)
  isArchived Boolean  @default(false)
  isLore     Boolean  @default(false)
  narrative  String   @default("")
  publicOpinions String @default("{}")
  voice      String   @default("")
  gender     String   @default("")
  archetype  String   @default("")
  age        String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  project    Project? @relation(fields: [projectId], references: [id])
  projectId  String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String?
  analyses   AnalysisRecord[]

  @@index([projectId, isArchived])
  @@index([userId])
  @@index([name])
}

model AppSetting {
  id    String @id
  value String
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  characters    Character[]
  analyses      AnalysisRecord[]
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model RateLimit {
  ip        String   @id
  count     Int      @default(1)
  resetAt   DateTime
}

model AnalysisRecord {
  id            String    @id @default(cuid())
  characterId   String
  userId        String?
  provider      String?
  result        String    // JSON string
  dataSnapshot  String?   // JSON string
  createdAt     DateTime  @default(now())

  character     Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([userId])
}
