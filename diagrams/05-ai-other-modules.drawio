        </mxCell>
        <mxCell id="r_flow2" value="POST /api/ai/[module]&lt;br&gt;SSE stream" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffd8a8;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="825" width="170" height="40" as="geometry"/>
