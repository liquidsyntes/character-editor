        </mxCell>
        <mxCell id="r_flow3" value="Typewriter append&lt;br&gt;to textarea" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d0bfff;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
