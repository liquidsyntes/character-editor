        <mxCell id="r_flow4" value="Save to database&lt;br&gt;via Server Action" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
