        <!-- Bottom: example flow for Fill -->
        <mxCell id="t_flow_title" value="Example: Full Fill prompt assembly" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=16;fontStyle=1;fontColor=#555555;" vertex="1" parent="1">
