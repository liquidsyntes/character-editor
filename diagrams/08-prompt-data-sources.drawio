        </mxCell>

        <mxCell id="r_flow3" value="3. Calculate fieldsToFill: filter empty fields&lt;br&gt;(or sectionIds/fieldIds if specified)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a5d8ff;strokeColor=#1e1e1e;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="760" width="400" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_flow3" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="560" y="800" as="sourcePoint"/><mxPoint x="560" y="820" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="r_flow4" value="4. getPromptTemplate('USER_FILL_PROMPT')&lt;br&gt;→ user template from DB&lt;br&gt;5. Replace {{SCHEMA_DESC}}, {{FIELDS_TO_FILL}},&lt;br&gt;{{GENDER_INSTRUCTION}}, {{CONTEXT}}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a5d8ff;strokeColor=#1e1e1e;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="360" y="820" width="420" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a_flow4" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="570" y="875" as="sourcePoint"/><mxPoint x="570" y="895" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="r_flow5" value="6. Return { system, user }&lt;br&gt;→ POST to AI provider as messages array&lt;br&gt;[{role: 'system', content: system}, {role: 'user', content: user}]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#27ae60;fontSize=12;align=center;fontStyle=1;" vertex="1" parent="1">
