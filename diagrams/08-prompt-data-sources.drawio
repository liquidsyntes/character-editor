        </mxCell>

        <mxCell id="r_flow1" value="1. getPromptTemplate('FILL_PROMPT')&lt;br&gt;→ system prompt from DB&lt;br&gt;(or DEFAULT_FILL_SYSTEM_PROMPT)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a5d8ff;strokeColor=#1e1e1e;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
