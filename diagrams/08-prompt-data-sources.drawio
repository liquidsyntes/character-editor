        </mxCell>

        <mxCell id="r_flow2" value="2. Build schemaDesc: all 145 fields with&lt;br&gt;current values (or null) + placeholders" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a5d8ff;strokeColor=#1e1e1e;fontSize=12;align=left;spacingLeft=10;" vertex="1" parent="1">
