          <mxGeometry x="830" y="770" width="360" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="a_f8_f8a" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="810" as="sourcePoint"/><mxPoint x="1010" y="840" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- F8a: Process chunk -->
        <mxCell id="r_f8a" value="For each SSE chunk:&lt;br&gt;parsedChunk = JSON.parse(dataStr)&lt;br&gt;if (parsedChunk.text) → accumulate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=13;align=center;" vertex="1" parent="1">
          <mxGeometry x="840" y="840" width="340" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a_f8a_f8b" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="895" as="sourcePoint"/><mxPoint x="1010" y="925" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- F8b: Parse + setData -->
        <mxCell id="r_f8b" value="rawJson += parsedChunk.text&lt;br&gt;partial = parsePartialJson(rawJson)&lt;br&gt;if (!pushedUndo) { pushUndo(prev); pushedUndo = true }&lt;br&gt;setData(prev =&gt; ({ ...prev, ...partial }))" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#a5d8ff;strokeColor=#1e1e1e;fontSize=13;align=center;" vertex="1" parent="1">
          <mxGeometry x="800" y="925" width="420" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="a_f8b_f9" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="1005" as="sourcePoint"/><mxPoint x="1010" y="1040" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- F9: Finalize -->
        <mxCell id="r_f9" value="STREAM ENDS — FINALIZE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="890" y="1040" width="240" height="35" as="geometry"/>
        </mxCell>

        <!-- F9a-F9d same as section but for field -->
        <mxCell id="a_f9_f9a" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="1075" as="sourcePoint"/><mxPoint x="1010" y="1105" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r_f9a" value="clearTimeout(saveTimer)&lt;br&gt;saveTimer = setTimeout(doSave, 800) // debounced" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="860" y="1105" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_f9a_f9b" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="1155" as="sourcePoint"/><mxPoint x="1010" y="1185" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r_f9b" value="setFixedFields(Object.keys(finalParsed))&lt;br&gt;setTimeout(() =&gt; setFixedFields([]), 5000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="860" y="1185" width="300" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_f9b_f9c" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="1235" as="sourcePoint"/><mxPoint x="1010" y="1265" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="r_f9c" value="setAiProgress({ isVisible: false,&lt;br&gt;label: '✓ ' + modelName + ' • N tokens' })&lt;br&gt;setTimeout(clear, 6000)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="850" y="1265" width="320" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a_f9c_f10" style="endArrow=classic;html=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint x="1010" y="1320" as="sourcePoint"/><mxPoint x="1010" y="1350" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- F10: Done -->
        <mxCell id="e_f10" value="DONE" style="ellipse;whiteSpace=wrap;html=1;fillColor=#b2f2bb;strokeColor=#1e1e1e;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="960" y="1350" width="100" height="40" as="geometry"/>
        </mxCell>

        <!-- F-Error path -->
        <mxCell id="r_f_catch" value="CATCH block:&lt;br&gt;clearTimeout(timeoutId)&lt;br&gt;AbortError? → setAiError('Запрос отменён')&lt;br&gt;Otherwise → setAiError(errMsg)&lt;br&gt;setAiProgress(null)&lt;br&gt;setAiFieldLoading(null)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffc9c9;strokeColor=#cc0000;fontSize=13;align=center;dashed=1;dashPattern=4 4;" vertex="1" parent="1">
          <mxGeometry x="720" y="1420" width="620" height="90" as="geometry"/>
        </mxCell>

        <!-- ============== SHARED NOTES SECTION ============== -->
        <mxCell id="r_notes_bg" value="KEY DIFFERENCES: Section vs Field Autofill" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#c3fae8;strokeColor=#1e1e1e;fontSize=18;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="1700" width="1310" height="200" as="geometry"/>
        </mxCell>

        <!-- Note 1 -->
        <mxCell id="r_note1" value="MUTEX CHECK&lt;br&gt;&lt;br&gt;Section: only checks aiSectionLoading&lt;br&gt;(allows concurrent field + section)&lt;br&gt;&lt;br&gt;Field: checks aiFieldLoading&lt;br&gt;|| aiSectionLoading || aiLoading&lt;br&gt;(blocks during any AI operation)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="50" y="1740" width="290" height="140" as="geometry"/>
        </mxCell>

        <!-- Note 2 -->
        <mxCell id="r_note2" value="PROMPT SCOPE&lt;br&gt;&lt;br&gt;Section: buildFillPrompt&lt;br&gt;filters CHARACTER_SCHEMA to&lt;br&gt;only the section's fields&lt;br&gt;&lt;br&gt;Field: buildFillPrompt&lt;br&gt;generates prompt for&lt;br&gt;a single field only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="370" y="1740" width="290" height="140" as="geometry"/>
        </mxCell>

        <!-- Note 3 -->
        <mxCell id="r_note3" value="PROGRESS TRACKING&lt;br&gt;&lt;br&gt;Section: total = section.fields.length&lt;br&gt;current updates per parsed field&lt;br&gt;&lt;br&gt;Field: total = 1&lt;br&gt;current stays at 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="690" y="1740" width="290" height="140" as="geometry"/>
        </mxCell>

        <!-- Note 4 -->
        <mxCell id="r_note4" value="POST-PROCESSING&lt;br&gt;&lt;br&gt;Section: setOpenSections adds&lt;br&gt;the section to visible set&lt;br&gt;&lt;br&gt;Field: no openSections change&lt;br&gt;(field is already visible in&lt;br&gt;its open section)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3bf;strokeColor=#1e1e1e;fontSize=14;align=center;" vertex="1" parent="1">
          <mxGeometry x="1010" y="1740" width="290" height="140" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
