        <mxCell id="t_shared_title" value="SHARED post-processing (all 3 levels: full / section / field):" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;" vertex="1" parent="1">
